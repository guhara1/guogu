---
/**
 * 서울 허브 페이지 (/seoul/)
 * 스펙 5절 서울 구조 - 25개 행정구 전체 그리드
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import Checklist from '../../components/Checklist.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import PriceTable from '../../components/PriceTable.astro';
import { getDistricts, getReadyLifeAreas } from '../../lib/data';
import { webPageSchema, breadcrumbSchema, imageObjectSchema } from '../../lib/schema';

const path = '/seoul/';
const title = '서울 출장마사지｜25개 행정구 방문 가능 지역 안내';
const description =
  '서울 출장마사지 25개 행정구별 방문 가능 지역과 행정동, 역세권, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('seoul');
const seoulAreas = getReadyLifeAreas('seoul');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '서울', url: '/seoul/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  imageObjectSchema('/og-image-square.webp', `${title}`),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    {/* 히어로 — 바다/야자수 서머 톤 */}
    <Hero
      align="left"
      badge="서울 · 수도권 출장마사지"
      title="서울 출장마사지 ·"
      highlight="25개 행정구 안내"
      subtitle="서울은 25개 행정구와 핵심 역세권, 생활권을 기준으로 방문 환경을 안내합니다. 행정구를 클릭하면 해당 구의 행정동 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다."
      ctas={[
        { label: '예약 전 확인', href: '/check/', variant: 'outline' },
        { label: '생활권 보기', href: '/life/', variant: 'ghost' },
      ]}
      heroImage="/og-image.webp"
      heroImageAlt="서울 출장마사지 25개 행정구 방문 가능 지역 안내 - 강남 잠실 홍대 여의도 역세권"
    />

    {/* 25개 행정구 그리드 - 핵심! */}
    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">서울 25개 행정구</h2>
      <p class="section-subtitle">
        행정구를 클릭하면 행정동 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/seoul/${d.slug}/`} class="card">
            <h3 class="card__title">{d.name}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-gold">{d.dongs?.length ?? 0}개 동</span>
              <span class="tag">{d.contentFocus}</span>
            </div>
            <span class="card__link">행정동 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    {/* 가격표 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="서울 출장마사지 가격표" />
    </section>

    {/* 전화 CTA */}
    <PhoneCTA />

    {/* 핵심 생활권 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">서울 핵심 생활권</h2>
      <p class="section-subtitle">
        행정구가 아닌 실제 생활권 단위로 방문 특성을 확인하세요.
      </p>
      <div class="card-grid">
        {seoulAreas.map((area) => (
          <a href={`/seoul/life/${area.slug}/`} class="card">
            <div class="tag tag-gold" style="margin-bottom: 12px; display: inline-block;">서울 생활권</div>
            <h3 class="card__title">{area.name}</h3>
            <p class="card__desc">{area.description}</p>
            <span class="card__link">방문 가능 지역 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    {/* 예약 전 체크리스트 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
