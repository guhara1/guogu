---
/**
 * 서울 행정동(법정동) 상세 페이지
 * /seoul/[district]/[dong]/  (예: /seoul/gangnam-gu/dong-1/)
 *
 * SEO 스펙 준수:
 *  - 도어웨이 페이지 방지: 각 동마다 고유 title/description/h1/FAQ/본문
 *  - 메뉴명 "출장마사지" 과다 반복 금지
 *  - 동 특화 콘텐츠: 주거환경, 출입특성, 인근역, 인근 생활권, 동별 FAQ
 *  - 구 ↔ 동 ↔ 생활권/역사권 양방향 내부 링크
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import DistrictNav from '../../../components/DistrictNav.astro';
import Checklist from '../../../components/Checklist.astro';
import PriceTable from '../../../components/PriceTable.astro';
import PhoneCTA from '../../../components/PhoneCTA.astro';
import {
  getDistricts,
  getDistrict,
  getDongList,
  getDong,
  findLifeAreaBySlug,
  stationLabel,
  postposition,
  PROVINCE_LABEL,
} from '../../../lib/data';
import { webPageSchema, breadcrumbSchema, faqPageSchema } from '../../../lib/schema';

export const getStaticPaths = (() => {
  const paths = [];
  const districts = getDistricts('seoul');
  for (const d of districts) {
    const dongs = getDongList('seoul', d.slug);
    for (const dong of dongs) {
      paths.push({
        params: { district: d.slug, dong: dong.slug },
        props: { district: d, dong },
      });
    }
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props {
  district: ReturnType<typeof getDistricts>[number];
  dong: { name: string; slug: string };
}

const { district, dong } = Astro.props;
const dName = district.name; // 강남구
const dShort = dName.replace(/구$/, ''); // 강남
const dongName = dong.name; // 역삼동

const path = `/${'seoul'}/${district.slug}/${dong.slug}/`;

// 동 특화 메타 (고유성 보장)
const dongSubject = postposition(dongName, '은는'); // 역삼동은
const title = `${dName} ${dongName} 출장마사지｜방문 가능 지역 · 예약 전 확인사항`;
const description = `서울 ${dName} ${dongName} 출장마사지 방문 가능 지역 안내. ${dongName} 주거환경, 출입 특성, 인근 역세권과 예약 전 확인사항을 확인하세요. 전화예약 0508-202-4719.`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '서울', url: '/seoul/' },
  { name: dName, url: `/${'seoul'}/${district.slug}/` },
  { name: dongName, url: path },
];

// 동이 속한 생활권 추정 (representativeLifeAreas에서)
const relatedAreas = (district.representativeLifeAreas ?? [])
  .map((slug) => findLifeAreaBySlug(slug))
  .filter(Boolean);

// 동 특화 FAQ (도어웨이 방지용 고유 콘텐츠)
const faqs = [
  {
    question: `${dName} ${dongName}에서 출장마사지 예약이 가능한가요?`,
    answer: `네, ${dongSubject} ${dName} 관할로 방문 예약이 가능한 지역입니다. 다만 아파트·오피스텔·호텔 등 건물에 따라 공동현관 출입 방식(비밀번호·관리실 안내)이 다르므로, 예약 시 정확한 주소와 출입 방식을 미리 안내해 주세요.`,
  },
  {
    question: `${dongName} 출장 추가 이동비가 있나요?`,
    answer: `서울 ${dName} ${dongName}의 기본 출장 이동비는 4만원입니다. 다만 심야 시간대나 도로 접근이 제한적인 지역의 경우 추가 이동비가 발생할 수 있으니 예약 시 확인해 주세요.`,
  },
  {
    question: `${dongName} 호텔·오피스텔에서도 이용 가능한가요?`,
    answer: `${dongName} 내 호텔·오피스텔 이용은 건물 출입 정책에 따라 다릅니다. 외부인 출입을 제한하는 숙소·건물이 있으므로, 예약 시 숙소명 또는 건물명을 알려주시면 출입 가능 여부를 확인해 드립니다.`,
  },
  {
    question: `${dongName} 주변에 어떤 역세권이 있나요?`,
    answer: `${dongSubject} ${dName}의 행정동으로, ${district.nearbyStationsData && district.nearbyStationsData.length > 0 ? `${stationLabel(district.nearbyStationsData[0])} 등 주요 역세권과 인접해 있습니다.` : '역세권 접근성은 예약 시 안내해 드립니다.'} 역 기준으로 찾으시는 분들은 행정구 페이지의 역세권 안내를 참고하세요.`,
  },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(faqs),
];

// 같은 구의 다른 동 (내부 링크용, 최대 10개)
const siblingDongs = getDongList('seoul', district.slug)
  .filter((d) => d.slug !== dong.slug)
  .slice(0, 10);
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <DistrictNav province="seoul" districtSlug={district.slug} districtName={dName} active="dong" />

    {/* 헤더 */}
    <section style="padding: 28px 0 24px;">
      <div class="tag tag-gold" style="margin-bottom: 14px;">
        {PROVINCE_LABEL.seoul} · {dName} · 행정동
      </div>
      <h1 style="font-size: 1.85rem; font-weight: 800; line-height: 1.35; margin-bottom: 12px;">
        {dName} {dongName} 출장마사지 · 방문 가능 지역 안내
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.02rem;">
        {dongSubject} {dName} 관할 행정동으로 방문 예약이 가능한 지역입니다. 주소 기준으로 찾으시는 분들을 위해 {dongName}의 방문 환경과 예약 전 확인사항을 안내합니다.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px;">
        <a href="#info" class="btn btn-outline btn-sm">방문 환경</a>
        <a href="#station" class="btn btn-outline btn-sm">인근 역세권</a>
        <a href="#use" class="btn btn-outline btn-sm">이용 장소</a>
        <a href="#checklist" class="btn btn-outline btn-sm">예약 전 확인</a>
        <a href={`/${'seoul'}/${district.slug}/`} class="btn btn-outline btn-sm">{dName} 전체 동 보기</a>
      </div>
    </section>

    <hr class="divider" />

    {/* 동 방문 환경 안내 */}
    <section class="section-sm" id="info">
      <h2 class="section-title">{dongName} <span class="accent">방문 환경 안내</span></h2>
      <p class="section-subtitle">
        {dongName}의 주요 주거·상권 환경과 출입 특성을 기준으로 예약 시 참고사항을 안내합니다.
      </p>
      <div class="card-grid card-grid-2">
        <div class="card card-static">
          <h3 class="card__title">📍 주거·상권 환경</h3>
          <p class="card__desc">
            {dongSubject} {dName}에 위치한 행정동으로, 주거지와 상권이 혼재된 지역 특성을 고려해 예약 시간대를 정하시면 좋습니다. 공동주택(아파트·오피스텔)이 밀집한 경우 출입 확인이 중요합니다.
          </p>
        </div>
        <div class="card card-static">
          <h3 class="card__title">🚪 출입 특성</h3>
          <p class="card__desc">
            {dongName} 내 아파트·오피스텔·호텔은 공동현관 출입 통제가 있는 경우가 많습니다. 예약 시 도로명 주소와 건물명, 출입 방식(비밀번호·관리실·공동 출입구)을 미리 안내해 주세요.
          </p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    {/* 인근 역세권 */}
    <section class="section-sm" id="station">
      <h2 class="section-title">{dongName} 인근 <span class="accent">역세권 안내</span></h2>
      <p class="section-subtitle">
        {dongName} 주변 주요 지하철역 기준 안내입니다. 역 기준으로 찾으시는 분들은 참고하세요.
      </p>
      {district.nearbyStationsData && district.nearbyStationsData.length > 0 ? (
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {district.nearbyStationsData.map((s) => (
            <span class="tag tag-gold" style="padding: 11px 18px; font-size: 0.92rem;">{stationLabel(s)}</span>
          ))}
        </div>
      ) : (
        <div class="callout callout-info">
          {dongName} 주변 역세권 안내는 예약 시 안내해 드립니다.
        </div>
      )}
    </section>

    <hr class="divider" />

    {/* 이용 장소 */}
    <section class="section-sm" id="use">
      <h2 class="section-title">{dongName} <span class="accent">이용 장소별 확인사항</span></h2>
      <p class="section-subtitle">
        자택·호텔·오피스텔·야간 등 이용 상황별로 확인사항이 다릅니다.
      </p>
      <div class="card-grid">
        <a href="/use/home/" class="card"><h3 class="card__title">자택 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/hotel/" class="card"><h3 class="card__title">호텔·숙소 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/officetel/" class="card"><h3 class="card__title">오피스텔 이용</h3><span class="card__link">확인하기 →</span></a>
        <a href="/use/night/" class="card"><h3 class="card__title">야간 예약</h3><span class="card__link">확인하기 →</span></a>
      </div>
    </section>

    <hr class="divider" />

    {/* 가격표 */}
    <section class="section-sm" id="price">
      <h2 class="section-title">{dongName} <span class="accent">코스별 가격 안내</span></h2>
      <PriceTable />
    </section>

    <hr class="divider" />

    {/* 예약 전 체크리스트 */}
    <section class="section-sm" id="checklist">
      <Checklist />
    </section>

    <hr class="divider" />

    {/* 전화 CTA */}
    <PhoneCTA region={`${dName} ${dongName}`} />

    <hr class="divider" />

    {/* 동별 FAQ */}
    <section class="section-sm">
      <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-item__question">
              <span>{f.question}</span>
              <span class="faq-item__icon">+</span>
            </summary>
            <div class="faq-item__answer">{f.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <hr class="divider" />

    {/* 같은 구의 다른 동 */}
    <section class="section-sm" id="nearby">
      <h2 class="section-title" style="font-size: 1.4rem;">{dName} 다른 행정동</h2>
      <p class="section-subtitle">{dName}의 다른 행정동도 확인해 보세요.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {siblingDongs.map((d) => (
          <a href={`/${'seoul'}/${district.slug}/${d.slug}/`} class="tag tag-link">{d.name}</a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
