---
/**
 * 서울 행정구 허브 상세 페이지 (강남 샘플 구조 전면 개편)
 * /seoul/[district]/
 *
 * 스펙 준수:
 *  - 메뉴명/버튼에 "출장마사지" 반복 금지
 *  - 생활권·행정동·지하철역·이용장소·운영기준 하위 메뉴 구성
 *  - 번호동은 대표동으로 통합
 *  - 중복·도어웨이 방지 (각 섹션 역할 차별화)
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DistrictNav from '../../components/DistrictNav.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import LongTailLinks from '../../components/LongTailLinks.astro';
import {
  getDistricts,
  findLifeAreaBySlug,
  getAllUseCases,
  stationLabel,
  getDongList,
  PROVINCE_LABEL,
} from '../../lib/data';
import type { DistrictData } from '../../lib/types';
import { webPageSchema, breadcrumbSchema, faqPageSchema } from '../../lib/schema';

export const getStaticPaths = (() => {
  const districts = getDistricts('seoul');
  return districts.map((d) => ({
    params: { district: d.slug },
    props: { district: d },
  }));
}) satisfies GetStaticPaths;

interface Props {
  district: DistrictData;
}

const { district } = Astro.props;
const path = district.canonicalUrl;
const dName = district.name; // 예: 강남구
const dShort = dName.replace(/구$/, ''); // 예: 강남

const title = `서울 ${dName} 출장마사지｜생활권·행정동·역세권 방문 가능 지역 안내`;
const description = `서울 ${dName} 출장마사지 예약 전 ${dShort} 생활권별 방문 가능 지역과 행정동, 지하철역, 이용 장소별 확인사항을 안내합니다. ${district.description}`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '서울', url: '/seoul/' },
  { name: dName, url: path },
];

const useCases = getAllUseCases();
const relatedAreas = (district.representativeLifeAreas ?? [])
  .map((slug) => findLifeAreaBySlug(slug))
  .filter(Boolean);

const faqs = [
  {
    question: `${dName} 어디까지 방문 가능한가요?`,
    answer: `${dName} 전역(행정동 기준) 방문이 가능합니다. 단, 오피스텔·호텔은 관리 규정에 따라 출입이 제한될 수 있으니 예약 시 건물명과 출입 방식을 미리 안내해 주세요.`,
  },
  {
    question: `${dShort} 추가 이동비는 어떻게 되나요?`,
    answer: `서울 ${dName} 기본 출장 이동비는 4만원이며, 심야 시간대에는 추가 이동비가 발생할 수 있습니다. 예약 시 확인해 주세요.`,
  },
  {
    question: `${dName} 호텔·오피스텔에서도 이용 가능한가요?`,
    answer: `가능합니다만, 숙소와 오피스텔은 외부인 출입 정책이 건물마다 다릅니다. 예약 시 숙소명이나 건물명을 알려주시면 출입 가능 여부를 확인해 드립니다.`,
  },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  faqPageSchema(faqs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    {/* 서브 메뉴 */}
    <DistrictNav province="seoul" districtSlug={district.slug} districtName={dName} active="home" />

    {/* 헤더 */}
    <section style="padding: 28px 0 32px;">
      <div class="tag tag-gold" style="margin-bottom: 14px;">
        {PROVINCE_LABEL.seoul} · {district.contentFocus}
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        {dName} 출장마사지 · 생활권별 방문 가능 지역
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">
        {district.description}
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px;">
        <a href="#life" class="btn btn-outline btn-sm">생활권 보기</a>
        <a href="#dong" class="btn btn-outline btn-sm">행정동 보기</a>
        <a href="#station" class="btn btn-outline btn-sm">지하철역 보기</a>
        <a href="#use" class="btn btn-outline btn-sm">이용 장소</a>
        <a href="#checklist" class="btn btn-outline btn-sm">예약 전 확인</a>
      </div>
    </section>

    {/* 본문 */}
    {district.body && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <div class="prose">
          <p>{district.body}</p>
        </div>
      </section>
    )}

    <hr class="divider" />

    {/* 생활권 안내 */}
    <section class="section-sm" id="life">
      <h2 class="section-title">{dName} 주요 <span class="accent">생활권 안내</span></h2>
      <p class="section-subtitle">
        {dShort} 안에서도 업무지구·주거지·역세권마다 예약 기준이 다릅니다. 생활권별로 확인하세요.
      </p>
      {relatedAreas && relatedAreas.length > 0 ? (
        <div class="card-grid">
          {relatedAreas.map((area) => area && (
            <a href={`/seoul/life/${area.slug}/`} class="card">
              <div class="tag tag-gold" style="margin-bottom: 10px; display: inline-block;">생활권</div>
              <h3 class="card__title">{area.name}</h3>
              <p class="card__desc">{area.description}</p>
              <span class="card__link">상세보기 →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="callout callout-info">
          {dName} 핵심 생활권 안내는 현재 준비 중입니다. 행정동 안내에서 해당 지역의 방문 환경을 확인하세요.
        </div>
      )}
    </section>

    <hr class="divider" />

    {/* 행정동 안내 - 핵심 */}
    <section class="section-sm" id="dong">
      <h2 class="section-title">{dName} <span class="accent">행정동별 방문 가능 지역</span></h2>
      <p class="section-subtitle">
        실제 주소 기준으로 찾는 분들을 위한 안내입니다. 번호동(1동·2동 등)은 대표동으로 통합해 안내합니다. 행정동을 클릭하면 해당 동의 방문 환경을 자세히 확인할 수 있습니다.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {getDongList('seoul', district.slug).map((dong) => (
          <a href={`/seoul/${district.slug}/${dong.slug}/`} class="tag tag-link" style="padding: 11px 18px; font-size: 0.92rem;">
            {dong.name}
          </a>
        ))}
      </div>
    </section>

    <hr class="divider" />

    {/* 지하철역 안내 */}
    <section class="section-sm" id="station">
      <h2 class="section-title">{dName} <span class="accent">주요 지하철역 안내</span></h2>
      <p class="section-subtitle">
        역 기준으로 찾는 분들을 위한 안내입니다. 역명 기준 1개만 안내하며, 출구별·노선별 페이지는 만들지 않습니다.
      </p>
      {district.nearbyStationsData && district.nearbyStationsData.length > 0 ? (
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {district.nearbyStationsData.map((s) => (
            <span class="tag tag-gold" style="padding: 11px 18px; font-size: 0.92rem;">{stationLabel(s)}</span>
          ))}
        </div>
      ) : (
        <div class="callout callout-info">
          {dName} 주요 역세권 안내는 현재 준비 중입니다.
        </div>
      )}
    </section>

    <hr class="divider" />

    {/* 이용 장소별 안내 */}
    <section class="section-sm" id="use">
      <h2 class="section-title">이용 장소에 따라 <span class="accent">확인할 내용이 다릅니다</span></h2>
      <p class="section-subtitle">
        자택·호텔·오피스텔·업무지구·야간 예약처럼 실제 이용 상황별로 확인사항이 다릅니다.
      </p>
      <div class="card-grid">
        {useCases.map((uc) => (
          <a href={`/use/${uc.slug}/`} class="card">
            <h3 class="card__title">{uc.label}</h3>
            <p class="card__desc">{uc.summary}</p>
            <span class="card__link">확인하기 →</span>
          </a>
        ))}
      </div>
    </section>

    <hr class="divider" />

    {/* 예약 전 체크리스트 */}
    <section class="section-sm" id="checklist">
      <Checklist />
    </section>

    <hr class="divider" />

    {/* 가격표 */}
    <section class="section-sm">
      <PriceTable title={`${dName} 출장마사지 가격표`} />
    </section>

    {/* 전화 CTA */}
    <PhoneCTA
      title={`${dName} 출장마사지 예약`}
      desc={`${dShort} 방문 가능 지역과 예약 시간을 전화로 안내받으세요.`}
    />

    <hr class="divider" />

    {/* 운영 기준 */}
    <section class="section-sm">
      <h2 class="section-title">안전한 이용을 위한 <span class="accent">운영 기준</span></h2>
      <div class="card-grid">
        <a href="/about/" class="card"><h3 class="card__title">사이트 소개</h3><span class="card__link">보기 →</span></a>
        <a href="/privacy/" class="card"><h3 class="card__title">개인정보 처리방침</h3><span class="card__link">보기 →</span></a>
        <a href="/contact/" class="card"><h3 class="card__title">불법·선정적 서비스 불가 안내</h3><span class="card__link">보기 →</span></a>
      </div>
    </section>

    <hr class="divider" />

    {/* FAQ */}
    <section class="section-sm">
      <h2 class="section-title" style="font-size: 1.5rem;">자주 묻는 질문</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-item__question">
              <span>{faq.question}</span>
              <span class="faq-item__icon">+</span>
            </summary>
            <div class="faq-item__answer">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    {/* 롱테일 키워드 내부링크 */}
    <LongTailLinks groups={[0, 2]} title={`${district.name} 출장마사지 관련 정보 더 보기`} />

  </div>
</BaseLayout>
