---
/**
 * 서울 행정구 상세 페이지 자동 생성
 * /seoul/[district]/  ← districts.json 의 25개 행정구 자동 생성
 * 각 페이지에 행정동 목록(dongs)과 내부 링크 표시
 */
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Checklist from '../../components/Checklist.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import LifeAreaCard from '../../components/LifeAreaCard.astro';
import { getDistricts, getDistrict, findLifeAreaBySlug, PROVINCE_LABEL } from '../../lib/data';
import type { DistrictData } from '../../lib/types';
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

export const getStaticPaths = (() => {
  const districts = getDistricts('seoul');
  return districts.map((d) => ({
    params: { district: d.slug },
    props: { district: d },
  }));
}) satisfies GetStaticPaths;

interface Props {
  district: DistrictData;
}

const { district } = Astro.props;
const path = district.canonicalUrl;
const title = `서울 ${district.name} 출장마사지｜행정동 방문 가능 지역 및 예약 전 확인`;
const description = `${district.name} 출장마사지 방문 가능 지역과 행정동별 특성, 예약 전 확인사항을 안내합니다. ${district.description}`;

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '서울', url: '/seoul/' },
  { name: district.name, url: path },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];

// 관련 생활권 (representativeLifeAreas 기반)
const relatedAreas = (district.representativeLifeAreas ?? [])
  .map((slug) => findLifeAreaBySlug(slug))
  .filter(Boolean);
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    {/* 헤더 */}
    <section style="padding: 24px 0 32px;">
      <div class="tag tag-gold" style="margin-bottom: 14px;">
        {PROVINCE_LABEL.seoul} · {district.contentFocus}
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; line-height: 1.35; margin-bottom: 14px;">
        서울 {district.name} 출장마사지
      </h1>
      <p style="color: var(--color-text-soft); font-size: 1.05rem;">
        {district.description}
      </p>
    </section>

    {/* 본문 */}
    {district.body && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <div class="prose">
          <p>{district.body}</p>
        </div>
      </section>
    )}

    {/* 행정동 목록 - 핵심! */}
    {district.dongs && district.dongs.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title">{district.name} 행정동 방문 가능 지역</h2>
        <p class="section-subtitle">
          {district.name} 산하 행정동을 확인하세요. 번호동(1동·2동 등)은 대표동으로 통합 안내합니다.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {district.dongs.map((dong) => (
            <span class="tag" style="padding: 10px 18px; font-size: 0.92rem;">{dong.replace(/-/g, ' ')}</span>
          ))}
        </div>
      </section>
    )}

    {/* 대표 역세권 */}
    {district.nearbyStationsData && district.nearbyStationsData.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title" style="font-size: 1.4rem;">대표 역세권</h2>
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          {district.nearbyStationsData.map((s) => (
            <span class="tag tag-gold">{s.replace(/-/g, ' ')}</span>
          ))}
        </div>
      </section>
    )}

    {/* 관련 생활권 */}
    {relatedAreas && relatedAreas.length > 0 && (
      <section class="section-sm" style="border-top: 1px solid var(--color-border);">
        <h2 class="section-title" style="font-size: 1.4rem;">관련 생활권</h2>
        <div class="card-grid">
          {relatedAreas.map((area) => area && <LifeAreaCard area={area} />)}
        </div>
      </section>
    )}

    {/* 전화 CTA */}
    <PhoneCTA
      title={`서울 ${district.name} 출장마사지 예약`}
      desc={`${district.name} 방문 가능 지역과 예약 시간을 전화로 안내받으세요.`}
    />

    {/* 예약 전 체크리스트 */}
    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
