---
/**
 * 인천 허브 페이지 (/incheon/)
 * 스펙 7절 인천 구조 - 8구 2군 전체 그리드
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import Checklist from '../../components/Checklist.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import PriceTable from '../../components/PriceTable.astro';
import { getDistricts, getReadyLifeAreas } from '../../lib/data';
import { webPageSchema, breadcrumbSchema, imageObjectSchema } from '../../lib/schema';

const path = '/incheon/';
const title = '인천 출장마사지｜8구 2군 방문 가능 지역 안내';
const description =
  '인천 출장마사지 8구 2군별 방문 가능 지역과 행정동, 역세권, 도서지역, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('incheon');
const incheonAreas = getReadyLifeAreas('incheon');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '인천', url: '/incheon/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  imageObjectSchema('/og-image-square.webp', `${title}`),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    {/* 히어로 — 바다/야자수 서머 톤 */}
    <Hero
      align="left"
      badge="인천 · 수도권 출장마사지"
      title="인천 출장마사지 ·"
      highlight="8구 2군 안내"
      subtitle="인천은 8구 2군 생활권과 공항·도서 지역 특성을 함께 안내합니다. 구·군을 클릭하면 해당 지역의 행정동 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다. 강화·옹진은 도서 지역 특성상 사전 예약과 추가 이동비 확인이 필요합니다."
      ctas={[
        { label: '예약 전 확인', href: '/check/', variant: 'outline' },
        { label: '생활권 보기', href: '/life/', variant: 'ghost' },
      ]}
    />

    {/* 8구 2군 그리드 */}
    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">인천 8구 2군</h2>
      <p class="section-subtitle">
        구·군을 클릭하면 행정동 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/incheon/${d.slug}/`} class="card">
            <h3 class="card__title">{d.name}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-gold">{d.dongs?.length ?? 0}개 동</span>
              <span class="tag">{d.contentFocus}</span>
            </div>
            <span class="card__link">행정동 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    {/* 가격표 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="인천 출장마사지 가격표" />
    </section>

    <PhoneCTA />

    {/* 핵심 생활권 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">인천 핵심 생활권</h2>
      <p class="section-subtitle">
        구·군이 아닌 실제 생활권 단위로 방문 특성과 공항·도서 접근성을 확인하세요.
      </p>
      <div class="card-grid">
        {incheonAreas.map((area) => (
          <a href={`/incheon/life/${area.slug}/`} class="card">
            <div class="tag tag-gold" style="margin-bottom: 12px; display: inline-block;">인천 생활권</div>
            <h3 class="card__title">{area.name}</h3>
            <p class="card__desc">{area.description}</p>
            <span class="card__link">방문 가능 지역 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
