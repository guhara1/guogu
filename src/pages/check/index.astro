---
/**
 * 예약 전 확인 인덱스 (/check/)
 * 스펙 9절 / 10절 Section 4
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import Checklist from '../../components/Checklist.astro';
import PriceTable from '../../components/PriceTable.astro';
import { webPageSchema, breadcrumbSchema } from '../../lib/schema';

const path = '/check/';
const title = '출장마사지 예약 전 확인사항｜방문 주소·출입·이동비·개인정보 안내';
const description =
  '출장마사지 예약 전 반드시 확인할 사항을 안내합니다. 방문 주소, 건물 출입 방식, 호텔·오피스텔 규정, 외곽 추가 이동비, 개인정보 처리 기준까지 확인하세요.';

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '예약 전 확인', url: '/check/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <Hero
      align="left"
      badge="예약 전 확인 · 출장마사지"
      title="출장마사지"
      highlight="예약 전 확인사항"
      subtitle="예약 전에 반드시 확인해야 할 항목을 정리했습니다. 원활한 방문을 위해 아래 항목을 미리 점검해 주세요."
    />

    <section class="section-sm">
      <Checklist title="예약 전 반드시 확인할 내용" />
    </section>

    {/* 가격표 */}
    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <PriceTable />
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="callout callout-warning">
        <div class="callout__title">불법·선정적 서비스 불가 안내</div>
        본 안내는 합법적인 방문형 건강 관리(스포츠 마사지, 체형 관리 등) 정보 제공 목적입니다.
        불법 행위 및 선정적 서비스는 제공하지 않으며, 관련 문의는 받지 않습니다.
      </div>
    </section>

  </div>
</BaseLayout>
