---
/**
 * 고객센터 (/contact/)
 * 예약 문의 및 안내 채널
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import { webPageSchema, breadcrumbSchema } from '../lib/schema';

const path = '/contact/';
const title = '고객센터｜수도권 출장마사지 예약 문의 및 안내';
const description =
  '수도권 출장마사지 예약 문의 및 안내 채널입니다. 방문 가능 지역, 예약 전 확인사항, 개인정보 처리 관련 문의를 안내해 드립니다.';

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '고객센터', url: '/contact/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
];
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container container-narrow">
    <Breadcrumbs items={breadcrumbs} />

    <Hero
      align="left"
      badge="고객센터 · 예약 문의"
      title="고객센터"
      highlight="예약 문의 안내"
      subtitle="예약 문의 및 안내가 필요한 경우 아래 내용을 확인해 주세요. 문의 전 예약 전 확인사항을 먼저 읽어주시면 원활한 안내에 도움이 됩니다."
    />

    <section class="section-sm">
      <div class="card-grid">
        <div class="card">
          <h3 class="card__title">예약 문의</h3>
          <p class="card__desc">
            방문 가능 지역과 시간, 장소를 확인 후 문의해 주세요.
            정확한 안내를 위해 방문 주소와 예약 희망 시간을 함께 알려주세요.
          </p>
        </div>
        <div class="card">
          <h3 class="card__title">방문 가능 지역 확인</h3>
          <p class="card__desc">
            <a href="/seoul/">서울</a>·<a href="/gyeonggi/">경기</a>·<a href="/incheon/">인천</a>
            생활권별 방문 가능 여부를 안내해 드립니다. 외곽·도서 지역은 사전 확인이 필요할 수 있습니다.
          </p>
        </div>
        <div class="card">
          <h3 class="card__title">개인정보·운영 문의</h3>
          <p class="card__desc">
            <a href="/privacy/">개인정보 처리방침</a>과 운영 기준 관련 문의를 안내해 드립니다.
          </p>
        </div>
      </div>
    </section>

    <section class="section-sm" style="border-top: 1px solid var(--color-border);">
      <div class="callout callout-warning">
        <div class="callout__title">서비스 운영 안내</div>
        본 사이트는 합법적인 방문형 건강 관리(스포츠 마사지, 체형 관리 등) 정보 안내 목적으로 운영됩니다.
        불법 행위 및 선정적 서비스는 제공하지 않으며, 관련 문의는 받지 않습니다.
        허위 후기·가짜 평점·과장된 할인 문구는 사용하지 않습니다.
      </div>
    </section>

  </div>
</BaseLayout>
