---
/**
 * 경기 허브 페이지 (/gyeonggi/)
 * 스펙 6절 경기 구조 - 31개 시·군 전체 그리드
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import Checklist from '../../components/Checklist.astro';
import PhoneCTA from '../../components/PhoneCTA.astro';
import PriceTable from '../../components/PriceTable.astro';
import { getDistricts, getReadyLifeAreas } from '../../lib/data';
import { webPageSchema, breadcrumbSchema, imageObjectSchema } from '../../lib/schema';

const path = '/gyeonggi/';
const title = '경기 출장마사지｜31개 시·군 방문 가능 지역 안내';
const description =
  '경기도 출장마사지 31개 시·군별 방문 가능 지역과 읍면동, 역세권, 예약 전 확인사항을 안내합니다.';

const districts = getDistricts('gyeonggi');
const gyeonggiAreas = getReadyLifeAreas('gyeonggi');

const breadcrumbs = [
  { name: '홈', url: '/' },
  { name: '경기', url: '/gyeonggi/' },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  webPageSchema(path, title, description, breadcrumbs),
  imageObjectSchema('/og-image-square.webp', `${title}`),
];

// 권역별 분류
const zones = {
  south: ['수원', '성남', '용인', '화성', '평택', '안성', '이천', '여주', '광주', '과천', '의왕', '군포', '안양', '오산'],
  west: ['부천', '안산', '시흥', '광명', '김포', '구리', '하남'],
  north: ['고양', '파주', '의정부', '양주', '동두천', '남양주', '포천', '가평', '연천'],
  east: ['양평'],
};
const zoneLabels = { south: '경기남부', west: '경기서부', north: '경기북부', east: '경기동부' };
---

<BaseLayout title={title} description={description} path={path} schemas={schemas}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    {/* 히어로 — 바다/야자수 서머 톤 */}
    <Hero
      align="left"
      badge="경기 · 수도권 출장마사지"
      title="경기 출장마사지 ·"
      highlight="31개 시·군 안내"
      subtitle="경기도는 31개 시·군과 일반구, 신도시, 차량 이동 기준을 함께 안내합니다. 시·군을 클릭하면 해당 지역의 읍·면·동 방문 가능 지역과 예약 전 확인사항을 확인할 수 있습니다."
      ctas={[
        { label: '예약 전 확인', href: '/check/', variant: 'outline' },
        { label: '생활권 보기', href: '/life/', variant: 'ghost' },
      ]}
      heroImage="/og-image.webp"
      heroImageAlt="경기 출장마사지 31개 시군 방문 가능 지역 안내 - 수원 분당 판교 동탄 일산"
    />

    {/* 31개 시·군 그리드 */}
    <section class="section" style="border-top: 1px solid var(--color-border); padding-top: 48px;">
      <h2 class="section-title">경기 31개 시·군</h2>
      <p class="section-subtitle">
        시·군을 클릭하면 읍·면·동 방문 가능 지역과 역세권을 확인할 수 있습니다.
      </p>
      <div class="card-grid">
        {districts.map((d) => (
          <a href={`/gyeonggi/${d.slug}/`} class="card">
            <h3 class="card__title">{d.name}</h3>
            <p class="card__desc">{d.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px;">
              <span class="tag tag-gold">{d.dongs?.length ?? 0}개 읍면동</span>
              <span class="tag">{d.contentFocus}</span>
            </div>
            <span class="card__link">읍면동 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    {/* 가격표 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <PriceTable title="경기 출장마사지 가격표" />
    </section>

    <PhoneCTA />

    {/* 핵심 생활권 */}
    <section class="section" style="border-top: 1px solid var(--color-border);">
      <h2 class="section-title">경기 핵심 생활권</h2>
      <p class="section-subtitle">
        시·군이 아닌 실제 생활권 단위로 방문 특성과 차량 이동 기준을 확인하세요.
      </p>
      <div class="card-grid">
        {gyeonggiAreas.map((area) => (
          <a href={`/gyeonggi/life/${area.slug}/`} class="card">
            <div class="tag tag-gold" style="margin-bottom: 12px; display: inline-block;">경기 생활권</div>
            <h3 class="card__title">{area.name}</h3>
            <p class="card__desc">{area.description}</p>
            <span class="card__link">방문 가능 지역 보기 →</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--color-border);">
      <Checklist />
    </section>

  </div>
</BaseLayout>
